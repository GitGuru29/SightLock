<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/register_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Live camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter" />

    <!-- Top title (Clean Native styled) -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        android:text="Set Up Face Scan"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif"
        android:text="First, position your face in the camera frame."
        android:textColor="#A1A1A1"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- Oval Face Guide (Serves as the Reticle and Dark Screen Overlay) -->
    <com.example.sightlock.OvalFaceGuideView
        android:id="@+id/face_guide"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Central Information Box -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/face_guide">

        <!-- State instruction text -->
        <TextView
            android:id="@+id/tv_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Look directly at the camera"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <!-- Animated eye icon for blink step -->
        <ImageView
            android:id="@+id/iv_eye_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="16dp"
            android:src="@android:drawable/ic_menu_view"
            android:tint="#007AFF"
            android:visibility="gone" />

        <!-- Progress status label -->
        <TextView
            android:id="@+id/tv_capture_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif"
            android:text="Setting up..."
            android:textColor="#007AFF"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Advanced Debug Panel (Hidden by default) -->
    <LinearLayout
        android:id="@+id/debug_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#99000000"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView android:id="@+id/tv_debug_fps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00FF00" android:fontFamily="monospace" android:textSize="10sp" android:text="FPS: --"/>
        <TextView android:id="@+id/tv_debug_dist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00FF00" android:fontFamily="monospace" android:textSize="10sp" android:text="Dist (Width): --"/>
        <TextView android:id="@+id/tv_debug_yaw" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00FF00" android:fontFamily="monospace" android:textSize="10sp" android:text="Yaw (Y): --"/>
        <TextView android:id="@+id/tv_debug_pitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00FF00" android:fontFamily="monospace" android:textSize="10sp" android:text="Pitch (X): --"/>
        <TextView android:id="@+id/tv_debug_state" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00FF00" android:fontFamily="monospace" android:textSize="10sp" android:text="State: --"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
