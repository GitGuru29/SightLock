<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/overlay_background_gradient">

    <!-- Central warning content -->
    <LinearLayout
        android:id="@+id/warning_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/warning_card_background"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="48dp"
        android:paddingTop="48dp"
        android:paddingBottom="40dp">

        <!-- Pulsing shield icon -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal">

            <!-- Glow ring background -->
            <View
                android:id="@+id/shield_glow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shield_icon_circle" />

            <!-- Shield vector icon -->
            <ImageView
                android:id="@+id/shield_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:contentDescription="Privacy shield warning"
                android:src="@drawable/ic_shield_warning"
                android:tint="#0A0A0F" />
        </FrameLayout>

        <!-- Spacing -->
        <View
            android:layout_width="0dp"
            android:layout_height="32dp" />

        <!-- Alert header -->
        <TextView
            android:id="@+id/alert_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.2"
            android:text="CRITICAL THREAT"
            android:textColor="#FF003C"
            android:textSize="16sp" />

        <!-- Spacing -->
        <View
            android:layout_width="0dp"
            android:layout_height="8dp" />

        <!-- Main message -->
        <TextView
            android:id="@+id/main_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="ACCESS DENIED"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Spacing -->
        <View
            android:layout_width="0dp"
            android:layout_height="16dp" />

        <!-- Sub message -->
        <TextView
            android:id="@+id/sub_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="UNAUTHORIZED BIOMETRIC\nSIGNATURE DETECTED."
            android:textAlignment="center"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:textStyle="bold"
            android:lineSpacingExtra="6dp" />

        <!-- Spacing -->
        <View
            android:layout_width="0dp"
            android:layout_height="32dp" />

        <!-- Status indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Blinking dot -->
            <View
                android:id="@+id/status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/status_dot" />

            <View
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:text="SYSTEM LOCKED"
                android:textColor="#FF003C"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom accent line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="64dp"
        android:layout_marginHorizontal="64dp"
        android:background="@drawable/bottom_line_gradient" />

    <!-- Bottom brand text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.4"
        android:text="SIGHTLOCK"
        android:textColor="#33FFFFFF"
        android:textSize="14sp" />

</FrameLayout>
